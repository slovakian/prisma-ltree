{
  "name": "@prisma-next/test-utils",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma/dev": "catalog:",
    "@types/pg": "catalog:",
    "pg": "catalog:",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.mts",
      "import": "./dist/exports/index.mjs"
    },
    "./contract-factories": {
      "types": "./dist/exports/contract-factories.d.mts",
      "import": "./dist/exports/contract-factories.mjs"
    },
    "./column-descriptors": {
      "types": "./dist/exports/column-descriptors.d.mts",
      "import": "./dist/exports/column-descriptors.mjs"
    },
    "./lowered-params": {
      "types": "./dist/exports/lowered-params.d.mts",
      "import": "./dist/exports/lowered-params.mjs"
    },
    "./operation-descriptors": {
      "types": "./dist/exports/operation-descriptors.d.mts",
      "import": "./dist/exports/operation-descriptors.mjs"
    },
    "./semantic-lines": {
      "types": "./dist/exports/semantic-lines.d.mts",
      "import": "./dist/exports/semantic-lines.mjs"
    },
    "./timeouts": {
      "types": "./dist/exports/timeouts.d.mts",
      "import": "./dist/exports/timeouts.mjs"
    },
    "./typed-expectations": {
      "types": "./dist/exports/typed-expectations.d.mts",
      "import": "./dist/exports/typed-expectations.mjs"
    }
  }
}
