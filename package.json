{
  "name": "prisma-ltree-extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check packages/extension-ltree && vp run --filter ./packages/extension-ltree check-pins && vp run --filter ./packages/extension-ltree test && vp run --filter ./packages/extension-ltree build",
    "dev": "vp run web#dev",
    "prepare": "vp config",
    "sync-docs": "bash scripts/sync.sh",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "alchemy": "catalog:",
    "effect": "catalog:",
    "pkg-pr-new": "catalog:",
    "tslib": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
