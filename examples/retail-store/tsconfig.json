{
  "extends": ["@prisma-next/tsconfig/base"],
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "migrations/**/*.ts",
    "middleware.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["dist", "test/fixtures/**/*"]
}
