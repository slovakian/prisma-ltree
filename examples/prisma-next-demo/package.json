{
  "name": "prisma-next-demo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "emit": "prisma-next contract emit",
    "emit:check": "pnpm emit && git diff --exit-code src/prisma/contract.json src/prisma/contract.d.ts",
    "emit:psl": "prisma-next contract emit --config prisma-next.config.ts",
    "emit:ts": "prisma-next contract emit --config prisma-next.config.ts-contract.ts",
    "db:init": "prisma-next db init",
    "db:drop": "tsx scripts/drop-db.ts",
    "seed": "tsx scripts/seed.ts",
    "start": "tsx src/main.ts",
    "start:no-emit": "tsx src/main-no-emit.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:dual-mode": "pnpm emit:psl && pnpm test && pnpm emit:ts && pnpm test && pnpm emit:psl",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings"
  },
  "dependencies": {
    "@prisma-next/adapter-postgres": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/driver-postgres": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/extension-pgvector": "workspace:0.14.0",
    "@prisma-next/family-sql": "workspace:0.14.0",
    "@prisma-next/ids": "workspace:0.14.0",
    "@prisma-next/middleware-cache": "workspace:0.14.0",
    "@prisma-next/postgres": "workspace:0.14.0",
    "@prisma-next/sql-contract": "workspace:0.14.0",
    "@prisma-next/sql-contract-psl": "workspace:0.14.0",
    "@prisma-next/sql-contract-ts": "workspace:0.14.0",
    "@prisma-next/sql-builder": "workspace:0.14.0",
    "@prisma-next/sql-orm-client": "workspace:0.14.0",
    "@prisma-next/sql-relational-core": "workspace:0.14.0",
    "@prisma-next/sql-runtime": "workspace:0.14.0",
    "@prisma-next/target-postgres": "workspace:0.14.0",
    "arktype": "^2.2.2",
    "dotenv": "^17.4.2",
    "pg": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:0.14.0",
    "@prisma-next/emitter": "workspace:0.14.0",
    "@prisma-next/migration-tools": "workspace:0.14.0",
    "@prisma-next/sql-contract-emitter": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "@prisma-next/vite-plugin-contract-emit": "workspace:0.14.0",
    "@prisma/dev": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "jsdom": "^29.0.2",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "version": "0.14.0"
}
