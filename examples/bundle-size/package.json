{
  "name": "bundle-size",
  "private": true,
  "type": "module",
  "version": "0.14.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start:pg": "tsx src/postgres/main.ts",
    "start:pg:emit": "tsx src/postgres/main-emit.ts",
    "start:mongo": "tsx src/mongo/main.ts",
    "start:mongo:emit": "tsx src/mongo/main-emit.ts",
    "emit:pg": "prisma-next contract emit --config prisma-next.config.postgres.ts",
    "emit:mongo": "prisma-next contract emit --config prisma-next.config.mongo.ts",
    "emit": "pnpm emit:pg && pnpm emit:mongo",
    "bundle": "tsx scripts/bundle.ts",
    "size": "size-limit",
    "size:build": "pnpm --dir ../.. run build && pnpm bundle",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings"
  },
  "dependencies": {
    "@prisma-next/adapter-mongo": "workspace:0.14.0",
    "@prisma-next/adapter-postgres": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/mongo": "workspace:0.14.0",
    "@prisma-next/mongo-contract": "workspace:0.14.0",
    "@prisma-next/postgres": "workspace:0.14.0",
    "@prisma-next/sql-contract": "workspace:0.14.0",
    "@prisma-next/target-mongo": "workspace:0.14.0",
    "@prisma-next/target-postgres": "workspace:0.14.0",
    "mongodb": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:0.14.0",
    "@prisma-next/emitter": "workspace:0.14.0",
    "@prisma-next/family-mongo": "workspace:0.14.0",
    "@prisma-next/sql-contract-emitter": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma/dev": "catalog:",
    "@cloudflare/workers-types": "4.20260515.1",
    "@size-limit/file": "^12.1.0",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "esbuild": "^0.28.1",
    "mongodb-memory-server": "catalog:",
    "size-limit": "^12.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "4.91.0"
  }
}
