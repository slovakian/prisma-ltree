{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "migrations/**", "package.json", "tsconfig.json", "tsdown.config.ts"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "dist/**"],
      "env": ["TEST_TIMEOUT_MULTIPLIER"],
      "passThroughEnv": [
        "WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE",
        "CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE"
      ]
    },
    "test:journeys": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "dist/**"],
      "env": ["TEST_TIMEOUT_MULTIPLIER"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "dist/**"],
      "outputs": ["coverage/**"],
      "env": ["TEST_TIMEOUT_MULTIPLIER"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tsconfig.json"]
    },
    "lint": {
      "inputs": ["src/**", "test/**"]
    },
    "record": {
      "dependsOn": ["build"],
      "inputs": ["scripts/record.ts", "recordings/config.ts", "recordings/fixtures/**"],
      "outputs": ["recordings/svgs/**", "recordings/ascii/**"]
    },
    "clean": {
      "cache": false
    },
    "@prisma-next/sql-builder#emit": {
      "dependsOn": ["@prisma-next/cli#build"]
    }
  }
}
