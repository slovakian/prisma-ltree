// use prisma-next
//
// PSL equivalent of ../src/prisma/contract.ts. Same contract, expressed
// against the PSL surface introduced by the four framework primitives:
//
//   - namespace blocks (TML-2459)
//   - cross-contract FK references via colon-prefixed dot-qualified
//     type identifiers, e.g. supabase:auth.User (TML-2500)
//   - top-level `policy <name> { … }` blocks for RLS (TML-2501)
//   - role identifiers (anon, authenticated, …) resolve against
//     roles shipped by the supabase extensionPack
//
// Family / target / driver / adapter / extensionPacks are configured in
// prisma-next.config.ts, not here. To use this PSL contract instead of
// the TS one, the config's `contract` field would be switched from
// typescriptContract(contract, …) to prismaContract('./prisma/schema.prisma', …).

namespace public {
  model Profile {
    id        String   @id @default(uuid())
    userId    String   @unique(map: "profile_userId_unique")
    username  String   @unique(map: "profile_username_unique")
    bio       String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // Cross-contract FK. The `supabase:` prefix tells the framework
    // this targets the `supabase` contract space (resolved via
    // extensionPacks in prisma-next.config.ts); `auth.User` is the
    // namespace-qualified model identifier within that contract space.
    // Cascade across the contract-space boundary is the developer's
    // explicit opt-in — no diagnostic.
    user      supabase:auth.User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "profile_userId_fkey")

    // Inverse of Post.author. No FK lives on this side; cardinality is
    // captured by the array type.
    posts     Post[]

    @@map("profile")
  }

  model Post {
    id          String    @id @default(uuid())
    authorId    String
    title       String
    body        String
    publishedAt DateTime?
    createdAt   DateTime  @default(now())

    // Local within-namespace relation.
    author      Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade, map: "post_authorId_fkey")

    @@map("post")
  }

  // RLS policies live in the same namespace as the model they target.
  // The `target` key is a bare model reference; `operation` and `roles`
  // are bare identifiers; `using` / `withCheck` are quoted strings.
  // Multiple permissive policies for the same operation are allowed
  // (Postgres ORs them). The default `as = permissive` is omitted.

  policy profiles_select_anon_and_authed {
    target    = Profile
    operation = select
    roles     = [anon, authenticated]
    using     = "true"
  }

  // auth.uid() / auth.role() / auth.jwt() are Postgres functions
  // Supabase installs in the auth schema. They are NOT contract
  // elements in v0.1 — predicate strings are opaque to the framework,
  // and missing functions surface as Postgres errors at migration time.

  policy profiles_insert_own {
    target    = Profile
    operation = insert
    roles     = [authenticated]
    withCheck = "user_id = (auth.uid())::uuid"
  }

  policy profiles_update_own {
    target    = Profile
    operation = update
    roles     = [authenticated]
    using     = "user_id = (auth.uid())::uuid"
    withCheck = "user_id = (auth.uid())::uuid"
  }

  policy profiles_delete_own {
    target    = Profile
    operation = delete
    roles     = [authenticated]
    using     = "user_id = (auth.uid())::uuid"
  }

  policy posts_select_published {
    target    = Post
    operation = select
    roles     = [anon, authenticated]
    using     = "published_at IS NOT NULL"
  }

  // The TS surface's ({ ref }) => `… ${ref(Profile)} …` function form
  // does not have a v0.1 PSL equivalent. Qualified table identifiers
  // in predicate bodies are hard-coded; renaming Profile's table or
  // moving it to a different namespace requires updating the strings
  // below. A `${ModelName}` interpolation token recognised at lowering
  // time is a v0.2 stretch goal.

  policy posts_insert_own {
    target    = Post
    operation = insert
    roles     = [authenticated]
    withCheck = "author_id IN (SELECT id FROM \"public\".\"profile\" WHERE user_id = (auth.uid())::uuid)"
  }

  policy posts_update_own {
    target    = Post
    operation = update
    roles     = [authenticated]
    using     = "author_id IN (SELECT id FROM \"public\".\"profile\" WHERE user_id = (auth.uid())::uuid)"
    withCheck = "author_id IN (SELECT id FROM \"public\".\"profile\" WHERE user_id = (auth.uid())::uuid)"
  }

  policy posts_delete_own {
    target    = Post
    operation = delete
    roles     = [authenticated]
    using     = "author_id IN (SELECT id FROM \"public\".\"profile\" WHERE user_id = (auth.uid())::uuid)"
  }
}
