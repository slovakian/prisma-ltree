{
  "name": "@prisma-next/sql-relational-core",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "AST types, query lane context, and type utilities for Prisma Next SQL lanes",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/operations": "workspace:0.14.0",
    "@prisma-next/sql-contract": "workspace:0.14.0",
    "@prisma-next/sql-operations": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "@standard-schema/spec": "^1.1.0",
    "arktype": "catalog:",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma-next/sql-contract-ts": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./ast": "./dist/exports/ast.mjs",
    "./codec-descriptor-registry": "./dist/exports/codec-descriptor-registry.mjs",
    "./contract-free": "./dist/exports/contract-free.mjs",
    "./errors": "./dist/exports/errors.mjs",
    "./expression": "./dist/exports/expression.mjs",
    "./middleware": "./dist/exports/middleware.mjs",
    "./plan": "./dist/exports/plan.mjs",
    "./query-lane-context": "./dist/exports/query-lane-context.mjs",
    "./types": "./dist/exports/types.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/2-sql/4-lanes/relational-core"
  }
}
