{
  "name": "@prisma-next/emitter",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/operations": "workspace:0.14.0",
    "@prisma-next/ts-render": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "arktype": "^2.2.2",
    "prettier": "^3.9.4"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@types/node": "catalog:",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.mts",
      "import": "./dist/exports/index.mjs"
    },
    "./domain-type-generation": {
      "types": "./dist/domain-type-generation.d.mts",
      "import": "./dist/domain-type-generation.mjs"
    },
    "./type-expression-safety": {
      "types": "./dist/type-expression-safety.d.mts",
      "import": "./dist/type-expression-safety.mjs"
    },
    "./test/utils": {
      "types": "./dist/test/utils.d.mts",
      "import": "./dist/test/utils.mjs"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/3-tooling/emitter"
  }
}
