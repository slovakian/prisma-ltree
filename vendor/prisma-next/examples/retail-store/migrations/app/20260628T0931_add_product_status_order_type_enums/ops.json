[
  {
    "id": "validator.orders.update",
    "label": "Update validator on orders",
    "operationClass": "destructive",
    "precheck": [
      {
        "description": "collection orders exists",
        "source": {
          "kind": "listCollections"
        },
        "filter": {
          "kind": "field",
          "field": "name",
          "op": "$eq",
          "value": "orders"
        },
        "expect": "exists"
      }
    ],
    "execute": [
      {
        "description": "modify orders",
        "command": {
          "kind": "collMod",
          "collection": "orders",
          "validator": {
            "$jsonSchema": {
              "additionalProperties": false,
              "bsonType": "object",
              "properties": {
                "_id": {
                  "bsonType": "objectId"
                },
                "items": {
                  "bsonType": "array",
                  "items": {
                    "additionalProperties": false,
                    "bsonType": "object",
                    "properties": {
                      "amount": {
                        "bsonType": "int"
                      },
                      "brand": {
                        "bsonType": "string"
                      },
                      "image": {
                        "additionalProperties": false,
                        "bsonType": "object",
                        "properties": {
                          "url": {
                            "bsonType": "string"
                          }
                        },
                        "required": ["url"]
                      },
                      "name": {
                        "bsonType": "string"
                      },
                      "price": {
                        "additionalProperties": false,
                        "bsonType": "object",
                        "properties": {
                          "amount": {
                            "bsonType": "double"
                          },
                          "currency": {
                            "bsonType": "string"
                          }
                        },
                        "required": ["amount", "currency"]
                      },
                      "productId": {
                        "bsonType": "string"
                      }
                    },
                    "required": ["amount", "brand", "image", "name", "price", "productId"]
                  }
                },
                "shippingAddress": {
                  "bsonType": "string"
                },
                "statusHistory": {
                  "bsonType": "array",
                  "items": {
                    "additionalProperties": false,
                    "bsonType": "object",
                    "properties": {
                      "status": {
                        "bsonType": "string"
                      },
                      "timestamp": {
                        "bsonType": "date"
                      }
                    },
                    "required": ["status", "timestamp"]
                  }
                },
                "type": {
                  "bsonType": "string",
                  "enum": ["delivery", "pickup"]
                },
                "userId": {
                  "bsonType": "objectId"
                }
              },
              "required": ["_id", "items", "shippingAddress", "statusHistory", "type", "userId"]
            }
          },
          "validationLevel": "strict",
          "validationAction": "error"
        }
      }
    ],
    "postcheck": [
      {
        "description": "validator applied on orders",
        "source": {
          "kind": "listCollections"
        },
        "filter": {
          "kind": "and",
          "exprs": [
            {
              "kind": "field",
              "field": "name",
              "op": "$eq",
              "value": "orders"
            },
            {
              "kind": "field",
              "field": "options.validationLevel",
              "op": "$eq",
              "value": "strict"
            },
            {
              "kind": "field",
              "field": "options.validationAction",
              "op": "$eq",
              "value": "error"
            },
            {
              "kind": "field",
              "field": "options.validator.$jsonSchema",
              "op": "$eq",
              "value": {
                "additionalProperties": false,
                "bsonType": "object",
                "properties": {
                  "_id": {
                    "bsonType": "objectId"
                  },
                  "items": {
                    "bsonType": "array",
                    "items": {
                      "additionalProperties": false,
                      "bsonType": "object",
                      "properties": {
                        "amount": {
                          "bsonType": "int"
                        },
                        "brand": {
                          "bsonType": "string"
                        },
                        "image": {
                          "additionalProperties": false,
                          "bsonType": "object",
                          "properties": {
                            "url": {
                              "bsonType": "string"
                            }
                          },
                          "required": ["url"]
                        },
                        "name": {
                          "bsonType": "string"
                        },
                        "price": {
                          "additionalProperties": false,
                          "bsonType": "object",
                          "properties": {
                            "amount": {
                              "bsonType": "double"
                            },
                            "currency": {
                              "bsonType": "string"
                            }
                          },
                          "required": ["amount", "currency"]
                        },
                        "productId": {
                          "bsonType": "string"
                        }
                      },
                      "required": ["amount", "brand", "image", "name", "price", "productId"]
                    }
                  },
                  "shippingAddress": {
                    "bsonType": "string"
                  },
                  "statusHistory": {
                    "bsonType": "array",
                    "items": {
                      "additionalProperties": false,
                      "bsonType": "object",
                      "properties": {
                        "status": {
                          "bsonType": "string"
                        },
                        "timestamp": {
                          "bsonType": "date"
                        }
                      },
                      "required": ["status", "timestamp"]
                    }
                  },
                  "type": {
                    "bsonType": "string",
                    "enum": ["delivery", "pickup"]
                  },
                  "userId": {
                    "bsonType": "objectId"
                  }
                },
                "required": ["_id", "items", "shippingAddress", "statusHistory", "type", "userId"]
              }
            }
          ]
        },
        "expect": "exists"
      }
    ]
  },
