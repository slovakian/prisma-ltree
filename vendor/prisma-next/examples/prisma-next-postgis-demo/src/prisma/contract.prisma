// use prisma-next

types {
  // Geographic geometry — WGS84 (SRID 4326). Generates `geometry(Geometry, 4326)` in DDL
  // and types as `Geometry<4326>` in the emitted contract.d.ts.
  WgsGeometry = postgis.Geometry(4326)
}

/// A point-of-interest. `location` is a Point geometry in WGS84.
model Cafe {
  id       String      @id @default(uuid())
  name     String
  location WgsGeometry

  @@map("cafe")
}

/// A delivery route, captured as a single LineString in WGS84.
model Route {
  id   String      @id @default(uuid())
  name String
  path WgsGeometry

  @@map("route")
}

/// A neighborhood boundary, stored as a Polygon in WGS84.
model Neighborhood {
  id       String      @id @default(uuid())
  name     String
  boundary WgsGeometry

  @@map("neighborhood")
}
