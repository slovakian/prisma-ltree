    "label": "Add check constraint \"user_kind_check\" on \"user\".\"kind\"",
    "operationClass": "additive",
    "target": {
      "id": "postgres",
      "details": {
        "schema": "public",
        "objectType": "checkConstraint",
        "name": "user_kind_check",
        "table": "user"
      }
    },
    "precheck": [
      {
        "description": "ensure constraint \"user_kind_check\" does not exist",
        "sql": "SELECT NOT EXISTS (SELECT 1 AS \"one\" FROM \"pg_constraint\" AS \"c\" INNER JOIN \"pg_namespace\" AS \"n\" ON \"n\".\"oid\" = \"c\".\"connamespace\" WHERE (\"c\".\"conname\" = $1 AND \"n\".\"nspname\" = $2 AND \"c\".\"conrelid\" = to_regclass($3))) AS \"result\"",
        "params": ["user_kind_check", "public", "\"public\".\"user\""]
      }
    ],
    "execute": [
      {
        "description": "add check constraint \"user_kind_check\"",
        "sql": "ALTER TABLE \"public\".\"user\" ADD CONSTRAINT \"user_kind_check\" CHECK (\"kind\" IN ('admin', 'user'))"
      }
    ],
    "postcheck": [
      {
        "description": "verify constraint \"user_kind_check\" exists",
        "sql": "SELECT EXISTS (SELECT 1 AS \"one\" FROM \"pg_constraint\" AS \"c\" INNER JOIN \"pg_namespace\" AS \"n\" ON \"n\".\"oid\" = \"c\".\"connamespace\" WHERE (\"c\".\"conname\" = $1 AND \"n\".\"nspname\" = $2 AND \"c\".\"conrelid\" = to_regclass($3))) AS \"result\"",
        "params": ["user_kind_check", "public", "\"public\".\"user\""]
      }
    ]
