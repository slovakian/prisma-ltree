      {
        "description": "create extension \"vector\"",
        "sql": "CREATE EXTENSION IF NOT EXISTS vector"
      }
    ],
    "postcheck": [
      {
        "description": "confirm extension \"vector\" is enabled",
        "sql": "SELECT EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'vector')"
      }
    ]
  },
