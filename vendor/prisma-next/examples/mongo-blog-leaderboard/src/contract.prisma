model User {
  id      ObjectId @id @map("_id")
  name    String
  email   String
  bio     String?
  address Address?
  posts   Post[]
  @@map("users")
}

type Address {
  street  String
  city    String
  zip     String?
  country String
}

model Post {
  id        ObjectId @id @map("_id")
  title     String
  content   String
  kind      String
  authorId  ObjectId
  createdAt DateTime
  author    User     @relation(fields: [authorId], references: [id])

  @@discriminator(kind)
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

model Article {
  summary String
  @@base(Post, "article")
}

model Tutorial {
  difficulty String
  duration   Int
  @@base(Post, "tutorial")
}
