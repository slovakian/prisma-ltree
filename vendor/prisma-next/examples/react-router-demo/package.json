{
  "name": "react-router-demo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "emit": "prisma-next contract emit",
    "emit:psl": "PRISMA_NEXT_CONTRACT_SOURCE=psl prisma-next contract emit",
    "emit:ts": "PRISMA_NEXT_CONTRACT_SOURCE=ts prisma-next contract emit",
    "db:init": "prisma-next db init",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@prisma-next/adapter-postgres": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/driver-postgres": "workspace:0.14.0",
    "@prisma-next/family-sql": "workspace:0.14.0",
    "@prisma-next/postgres": "workspace:0.14.0",
    "@prisma-next/sql-contract": "workspace:0.14.0",
    "@prisma-next/sql-contract-psl": "workspace:0.14.0",
    "@prisma-next/sql-contract-ts": "workspace:0.14.0",
    "@prisma-next/sql-runtime": "workspace:0.14.0",
    "@prisma-next/target-postgres": "workspace:0.14.0",
    "@react-router/node": "^7.18.1",
    "@react-router/serve": "^7.18.1",
    "dotenv": "^17.4.2",
    "isbot": "^5.1.44",
    "pg": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:0.14.0",
    "@prisma-next/emitter": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/vite-plugin-contract-emit": "workspace:0.14.0",
    "@prisma/dev": "catalog:",
    "@react-router/dev": "^7.15.1",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "pathe": "^2.0.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  },
  "version": "0.14.0"
}
