// PSL contract source for the multi-extension-monorepo aggregate app.
//
// Declares one user-owned `User` table. The two internal extension
// packages (`packages/audit`, `packages/feature-flags`) contribute
// their own tables via separate contract spaces composed in
// `prisma-next.config.ts` under `extensionPacks`.

model User {
  id    String @id
  email String

  @@map("app_user")
}
