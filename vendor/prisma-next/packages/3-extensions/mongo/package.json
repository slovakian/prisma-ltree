{
  "name": "@prisma-next/mongo",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "One-package Mongo setup for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/adapter-mongo": "workspace:0.14.0",
    "@prisma-next/cli": "workspace:0.14.0",
    "@prisma-next/config": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/driver-mongo": "workspace:0.14.0",
    "@prisma-next/family-mongo": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/mongo-contract": "workspace:0.14.0",
    "@prisma-next/mongo-contract-psl": "workspace:0.14.0",
    "@prisma-next/mongo-contract-ts": "workspace:0.14.0",
    "@prisma-next/mongo-orm": "workspace:0.14.0",
    "@prisma-next/mongo-query-builder": "workspace:0.14.0",
    "@prisma-next/mongo-runtime": "workspace:0.14.0",
    "@prisma-next/target-mongo": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "mongodb": "catalog:",
    "@prisma-next/emitter": "workspace:0.14.0",
    "@prisma-next/mongo-emitter": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "mongodb-memory-server": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "mongodb": "^7.0.0",
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./bson": "./dist/bson.mjs",
    "./config": "./dist/config.mjs",
    "./contract-builder": "./dist/contract-builder.mjs",
    "./control": "./dist/control.mjs",
    "./family": "./dist/family.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./static": "./dist/static.mjs",
    "./target": "./dist/target.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-extensions/mongo"
  }
}
