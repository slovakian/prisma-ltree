{
  "name": "@prisma-next/driver-mongo",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "MongoDB driver for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/errors": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/mongo-lowering": "workspace:0.14.0",
    "@prisma-next/mongo-wire": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0"
  },
  "devDependencies": {
    "mongodb": "catalog:",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "mongodb-memory-server": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "mongodb": "^7.0.0",
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./control": "./dist/control.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-mongo-target/3-mongo-driver"
  }
}
