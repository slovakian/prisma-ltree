{
  "name": "@prisma-next/adapter-mongo",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "MongoDB adapter for Prisma Next (lowers commands to wire format)",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/config": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/errors": "workspace:0.14.0",
    "@prisma-next/family-mongo": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/migration-tools": "workspace:0.14.0",
    "@prisma-next/mongo-codec": "workspace:0.14.0",
    "@prisma-next/mongo-contract": "workspace:0.14.0",
    "@prisma-next/mongo-lowering": "workspace:0.14.0",
    "@prisma-next/mongo-query-ast": "workspace:0.14.0",
    "@prisma-next/mongo-query-builder": "workspace:0.14.0",
    "@prisma-next/mongo-schema-ir": "workspace:0.14.0",
    "@prisma-next/mongo-value": "workspace:0.14.0",
    "@prisma-next/mongo-wire": "workspace:0.14.0",
    "@prisma-next/operations": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "arktype": "catalog:",
    "bson": "^7.3.1"
  },
  "devDependencies": {
    "mongodb": "catalog:",
    "@prisma-next/driver-mongo": "workspace:0.14.0",
    "@prisma-next/errors": "workspace:0.14.0",
    "@prisma-next/mongo-contract-psl": "workspace:0.14.0",
    "@prisma-next/psl-parser": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "mongodb-memory-server": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "mongodb": "^7.0.0",
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./codec-ids": "./dist/codec-ids.mjs",
    "./codec-types": "./dist/codec-types.mjs",
    "./codecs": "./dist/codecs.mjs",
    "./control": "./dist/control.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-mongo-target/2-mongo-adapter"
  }
}
