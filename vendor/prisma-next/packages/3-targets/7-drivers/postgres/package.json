  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./control": "./dist/control.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-targets/7-drivers/postgres"
  }
