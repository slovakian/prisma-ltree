{
  "name": "@prisma-next/config",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "Prisma Next config authoring types and validation",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "arktype": "^2.2.2",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./config-types": "./dist/config-types.mjs",
    "./config-validation": "./dist/config-validation.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/1-core/config"
  }
}
