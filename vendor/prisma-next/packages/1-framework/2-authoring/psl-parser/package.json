{
  "name": "@prisma-next/psl-parser",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "Reusable parser for Prisma Schema Language (PSL)",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/config": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./format": "./dist/format.mjs",
    "./interpret": "./dist/interpret.mjs",
    "./syntax": "./dist/syntax.mjs",
    "./tokenizer": "./dist/tokenizer.mjs",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/2-authoring/psl-parser"
  }
}
