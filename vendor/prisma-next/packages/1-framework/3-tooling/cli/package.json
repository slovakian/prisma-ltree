{
  "name": "@prisma-next/cli",
  "version": "0.14.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsdown && node ./scripts/write-cli-js-compat.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "gallery": "tsx scripts/gallery.ts",
    "record": "tsx scripts/record.ts",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@prisma-next/config": "workspace:0.14.0",
    "@prisma-next/config-loader": "workspace:0.14.0",
    "@prisma-next/contract": "workspace:0.14.0",
    "@prisma-next/emitter": "workspace:0.14.0",
    "@prisma-next/errors": "workspace:0.14.0",
    "@prisma-next/framework-components": "workspace:0.14.0",
    "@prisma-next/language-server": "workspace:0.14.0",
    "@prisma-next/migration-tools": "workspace:0.14.0",
    "@prisma-next/psl-parser": "workspace:0.14.0",
    "@prisma-next/psl-printer": "workspace:0.14.0",
    "@prisma-next/cli-telemetry": "workspace:0.14.0",
    "@prisma-next/utils": "workspace:0.14.0",
    "arktype": "^2.2.2",
    "ci-info": "^4.3.1",
    "clipanion": "4.0.0-rc.4",
    "closest-match": "^1.3.3",
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "esbuild": "^0.28.1",
    "jsonc-parser": "^3.3.1",
    "package-manager-detector": "^1.7.0",
    "pathe": "^2.0.3",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@prisma-next/sql-contract": "workspace:0.14.0",
    "@prisma-next/sql-contract-emitter": "workspace:0.14.0",
    "@prisma-next/sql-contract-ts": "workspace:0.14.0",
    "@prisma-next/sql-operations": "workspace:0.14.0",
    "@prisma-next/sql-runtime": "workspace:0.14.0",
    "@prisma-next/test-utils": "workspace:0.14.0",
    "@prisma-next/tsconfig": "workspace:0.14.0",
    "@prisma-next/tsdown": "workspace:0.14.0",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.mts",
      "import": "./dist/exports/index.mjs"
    },
