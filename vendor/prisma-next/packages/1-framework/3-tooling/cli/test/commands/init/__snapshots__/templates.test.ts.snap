exports[`templates > minimalProjectReadmeMd > per-target snapshots > mongo readme is stable 1`] = `
"# my-app

Generated by \`prisma-next init\` with the Minimal template.

## First run

1. \`pnpm run db:up\` — start the local MongoDB replica set with \`mongodb-memory-server\`. Data persists in \`.mongo-data/\` across restarts.
2. \`pnpm run dev\` — runs \`src/index.ts\`, which writes one row and reads it back.

## Available scripts

- \`pnpm run dev\` — run the Prisma Next sample script

### Database and migrations

- \`pnpm run contract:emit\` — emit contract artifacts after contract changes
- \`pnpm run db:up\` — start the local MongoDB replica set with \`mongodb-memory-server\`. Data persists in \`.mongo-data/\` across restarts.
- \`pnpm run db:down\` — stop the local MongoDB process (data preserved)
- \`pnpm run db:reset\` — stop and wipe \`.mongo-data/\` for a clean slate
- \`pnpm run migration:plan\` — create a MongoDB migration plan
- \`pnpm run migrate\` — apply the planned MongoDB migration
- \`pnpm run db:seed\` — insert sample users manually

## Prisma Next

Prisma Next setup is scaffolded in:

- \`prisma/contract.ts\`
- \`prisma-next.config.ts\`
- \`prisma/db.ts\`
- \`src/lib/prisma.ts\`

For provider-specific Prisma Next reference docs, see \`prisma-next.md\`. Prisma Next skills live in the upstream \`skills/\` directory: https://github.com/prisma/prisma-next/tree/main/skills.

Node-based Prisma Next projects expect Node.js 24 LTS or newer.
"
`;

exports[`templates > minimalProjectReadmeMd > per-target snapshots > postgres readme is stable 1`] = `
"# my-app

Generated by \`prisma-next init\` with the Minimal template.

## First run

1. \`pnpm run db:init\` — applies your contract to the database (creates tables, signs the marker).
2. \`pnpm run dev\` — runs \`src/index.ts\`, which writes one row and reads it back.

## Available scripts

- \`pnpm run dev\` — run the Prisma Next sample script

### Database and migrations

- \`pnpm run contract:emit\` — emit contract artifacts after contract changes
- \`pnpm run db:init\` — initialize database state manually
- \`pnpm run db:update\` — update database state manually
- \`pnpm run migration:plan\` — create a migration plan
- \`pnpm run migrate\` — apply a planned migration
- \`pnpm run db:seed\` — insert sample users manually (run after \`db:init\`)

## Prisma Next

Prisma Next setup is scaffolded in:

- \`prisma/contract.prisma\`
- \`prisma-next.config.ts\`
- \`prisma/db.ts\`
- \`src/lib/prisma.ts\`

For provider-specific Prisma Next reference docs, see \`prisma-next.md\`. Prisma Next skills live in the upstream \`skills/\` directory: https://github.com/prisma/prisma-next/tree/main/skills.

Node-based Prisma Next projects expect Node.js 24 LTS or newer.
"
`;

