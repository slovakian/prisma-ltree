# Local Supabase development URL. Use the Postgres connection string from
# `supabase status` (port 54322 by default for the local dev stack).
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres

# Symmetric secret for HS256-signed JWTs (Supabase's default for local dev).
# Find it via `supabase status` → `JWT secret`.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Alternative for production / hosted Supabase projects using asymmetric keys.
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/.well-known/jwks.json
