// use prisma-next

types {
  Email = String
}

enum Role {
  @@type("pg/text@1")
  USER = "USER"
  ADMIN = "ADMIN"
}

model User {
  id Int @id @default(autoincrement())
  email Email @unique
  role Role
  createdAt DateTime @default(now())
  isActive Boolean @default(true)
  profile Json?
}

model Post {
  id Int @id @default(autoincrement())
  userId Int
  title String
  rating Float?
  author User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  @@index([userId])
  @@unique([title, userId])
}
