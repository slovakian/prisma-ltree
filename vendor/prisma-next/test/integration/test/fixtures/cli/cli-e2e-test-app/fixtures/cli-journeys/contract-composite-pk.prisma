// use prisma-next

model Org {
  id          Int @id
  name        String
  memberships Membership[]
}

model User {
  id          Int @id
  email       String
  memberships Membership[]

  @@map("user")
}

model Membership {
  orgId  Int @map("org_id")
  userId Int @map("user_id")
  role   String

  org  Org  @relation(fields: [orgId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([orgId, userId], map: "membership_pkey")
  @@map("membership")
}
