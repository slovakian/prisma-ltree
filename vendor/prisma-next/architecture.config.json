  "rules": {
    "sameLayer": "allow",
    "downward": "allow",
    "upward": "deny",
    "crossDomain": "directional",
    "migrationToRuntime": "deny",
    "runtimeToMigration": "allowArtifactsOnly"
  },
  "crossDomainRules": {
    "framework": {
      "mayImportFrom": [],
      "reason": "Framework domain is the innermost/core domain and may not import from any other domain"
    },
    "sql": {
      "mayImportFrom": ["framework"],
      "reason": "SQL domain may import only from framework domain"
    },
    "mongo": {
      "mayImportFrom": ["framework"],
      "reason": "Mongo domain may import only from framework domain"
    },
    "targets": {
      "mayImportFrom": ["framework", "sql", "mongo"],
      "reason": "Targets domain may import from framework, sql, and mongo domains"
    },
    "extensions": {
      "mayImportFrom": ["framework", "sql", "mongo", "targets", "extensions"],
      "reason": "Extensions domain may import from any domain"
    }
  },
  "planeRules": {
    "shared": {
      "allow": ["shared"],
      "forbid": ["migration", "runtime"],
      "exceptions": []
    },
    "migration": {
      "allow": ["shared", "migration"],
      "forbid": ["runtime"],
      "exceptions": []
    },
    "runtime": {
      "allow": ["shared", "runtime"],
      "forbid": ["migration"],
      "exceptions": []
    }
  },
  "crossDomainExceptions": [],
  "layerOrder": {
    "framework": ["foundation", "core", "authoring", "tooling"],
    "sql": ["core", "authoring", "tooling", "lanes", "runtime", "adapters", "drivers", "family"],
    "mongo": [
      "foundation",
      "authoring",
      "tooling",
      "query",
      "query-builders",
      "transport",
      "runtime",
      "family"
    ]
  }
}
